# ============================================
# PORTFOLIO-INFRA .gitignore
# Dernière mise à jour : 2025-01-24
# ============================================

# ---------------------------
# SECRETS (CRITIQUE - JAMAIS DANS GIT)
# ---------------------------
.env
.env.local
.env.production
*.pem
*.key
id_ed25519*

# ---------------------------
# WORDPRESS CORE
# On ne versionne PAS le core WordPress.
# Docker le fournit via l'image officielle.
# On ne versionne que NOTRE code (thème enfant, plugin).
# ---------------------------
wp-admin/
wp-includes/
wp-config.php
wp-config-sample.php
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/
wp-content/backups/
wp-content/blogs.dir/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php

# Ne pas ignorer notre thème enfant et notre plugin
# (on les inclura explicitement plus tard)

# ---------------------------
# WORDPRESS PLUGINS/THEMES TIERS
# Installés via WordPress, pas via Git
# ---------------------------
wp-content/plugins/*
wp-content/themes/*

# SAUF nos créations (on "dé-ignore" nos dossiers)
!wp-content/plugins/mon-plugin/
!wp-content/themes/mon-theme-enfant/

# ---------------------------
# SYSTÈME & ÉDITEURS
# ---------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.log

# ---------------------------
# DOCKER
# ---------------------------
# Les données persistantes de la BDD
db_data/

# ---------------------------
# BACKUPS LOCAUX
# ---------------------------
*.sql
*.sql.gz
*.tar.gz
backups/

# ---------------------------
# CERTIFICATS SSL (SECRETS)
# ---------------------------
certbot/

# ---------------------------
# WORDPRESS - Fichiers générés
# ---------------------------
wp-content/uploads/
wp-content/upgrade/

# ---------------------------
# WORDPRESS - Thèmes tiers
# ---------------------------
wp-content/themes/*
!wp-content/themes/twentytwentyfive-child/

# ---------------------------
# WORDPRESS - Plugins tiers
# ---------------------------
wp-content/plugins/*
!wp-content/plugins/portfolio-projets/

# ---------------------------
# WORDPRESS - Fichiers core/cache
# ---------------------------
wp-content/index.php
wp-content/languages/
wp-content/litespeed/
wp-content/.litespeed_conf.dat
