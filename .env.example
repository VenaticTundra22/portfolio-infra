# ============================================
# VARIABLES D'ENVIRONNEMENT — TEMPLATE
# ============================================
# INSTRUCTIONS :
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir chaque valeur avec VOS propres secrets
# 3. Ne JAMAIS commiter le fichier .env
# ============================================

# --- Base de données (MariaDB) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password_here
MYSQL_DATABASE=CHANGE_ME_database_name
MYSQL_USER=CHANGE_ME_database_user
MYSQL_PASSWORD=CHANGE_ME_database_password

# --- WordPress ---
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=${MYSQL_DATABASE}
WORDPRESS_DB_USER=${MYSQL_USER}
WORDPRESS_DB_PASSWORD=${MYSQL_PASSWORD}
WORDPRESS_TABLE_PREFIX=wp_

# --- Domaine ---
DOMAIN_NAME=CHANGE_ME_example.com